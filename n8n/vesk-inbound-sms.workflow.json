    {
      "parameters": {
        "jsCode": "// Deterministic threshold policy - mirrors ReplyHandlingAgent action rules.\n// The LLM only classifies; the 0.85 / 0.75 gates that trigger real actions live here.\nconst res = $input.first().json;\nconst msg = (res.choices && res.choices[0] && res.choices[0].message) || {};\nconst call = (msg.tool_calls || [])[0];\nlet intent = 'Other', confidence = 0, reasoning = 'no tool call returned';\nif (call) {\n  const args = JSON.parse(call.function.arguments);\n  intent = args.intent; confidence = Number(args.confidence); reasoning = args.reasoning || '';\n}\nconst ACTIONABLE = ['Confirm','Cancel','Reschedule'];\nlet action = 'log';\nif (ACTIONABLE.includes(intent) && confidence >= 0.85) action = 'auto-' + intent.toLowerCase();\nelse if (confidence < 0.75) action = 'escalate';\nreturn [{ json: { intent, confidence, reasoning, action } }];"
      },
