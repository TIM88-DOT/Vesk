    {
      "parameters": {
        "jsCode": "// Twilio posts form-encoded fields; the webhook node puts them under .body\nconst src = $input.first().json;\nconst body = src.body || src;\nconst smsSid = body.MessageSid || body.SmsSid || '';\nconst from = body.From || '';\nconst to = body.To || '';\nconst text = (body.Body || '').toString();\nconst normalized = text.trim();\n\n// Idempotency: dedup on Twilio MessageSid (mirrors the ProviderSmsSid unique key).\n// NOTE: workflow static data is best-effort and NOT atomic - see README comparison.\nconst store = $getWorkflowStaticData('global');\nstore.seenSids = store.seenSids || {};\nconst isDuplicate = Boolean(smsSid && store.seenSids[smsSid]);\nif (smsSid) store.seenSids[smsSid] = true;\n\n// Deterministic keyword gate (mirrors MessagingService StopKeywords/StartKeywords).\n// Legal opt-out must never depend on an LLM, so it is handled here, before classify.\nconst STOP = ['STOP','STOPALL','UNSUBSCRIBE','END','QUIT','ARRET','ARRETER'];\nconst START = ['START','UNSTOP','YES','OUI'];\nconst upper = normalized.toUpperCase();\nlet route = 'classify';\nif (STOP.includes(upper)) route = 'stop';\nelse if (START.includes(upper)) route = 'start';\n\nreturn [{ json: { smsSid, from, to, text, normalized, isDuplicate, route } }];"
      },
