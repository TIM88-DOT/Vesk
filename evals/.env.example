# Copy to .env and fill in ONE provider:  cp .env.example .env

# --- Option A: OpenAI ---
OPENAI_API_KEY=sk-your-key-here
# Optional. Any chat model with function calling. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# --- Option B: Azure AI Foundry / Azure OpenAI (takes precedence if both set) ---
# Matches Vesk's production AzureOpenAIClient. Endpoint is the resource base URL.
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Optional. Defaults to 2024-10-21 (a GA version that supports tool calling).
# AZURE_OPENAI_API_VERSION=2024-10-21
